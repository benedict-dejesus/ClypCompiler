{"project":{"name":"Best Practices Gallery","uuid":"9f3fb362-37cd-445d-a1bd-303ea3544112","createdDate":"2026-07-17T10:57:27.602Z","modifiedDate":"2026-07-17T10:57:27.602Z","applicationVersion":"1.0.0","schemaVersion":"1.0.0"},"metadata":{"projectMetadata":{},"compilerMetadata":{"idCounters":{"carousel":1,"slide":3,"heading":3,"paragraph":3},"assetNameCounters":{}},"compatibilityMetadata":{"minSupportedSchemaVersion":"1.0.0","migrationsApplied":[]},"runtimeMetadata":{},"adapterMetadata":{}},"block":{"blockType":"carousel","rootId":"carousel_001","objects":{"carousel_001":{"id":"carousel_001","type":"carousel","category":"container","parentId":null,"children":["slide_001","slide_002","slide_003"],"content":{},"logic":{},"settings":{"autoAdvance":false},"layout":{}},"slide_001":{"id":"slide_001","type":"slide","category":"content","parentId":"carousel_001","children":["heading_001","paragraph_001"],"content":{"caption":"Best practice 1"},"logic":{},"settings":{},"layout":{}},"heading_001":{"id":"heading_001","type":"heading","category":"content","parentId":"slide_001","children":[],"content":{"text":"Open with empathy"},"logic":{},"settings":{"headingLevel":"h3"},"layout":{}},"paragraph_001":{"id":"paragraph_001","type":"paragraph","category":"content","parentId":"slide_001","children":[],"content":{"richText":"Acknowledge the customer’s situation before troubleshooting. “That sounds frustrating — let’s fix it together.”"},"logic":{},"settings":{},"layout":{}},"slide_002":{"id":"slide_002","type":"slide","category":"content","parentId":"carousel_001","children":["heading_002","paragraph_002"],"content":{"caption":"Best practice 2"},"logic":{},"settings":{},"layout":{}},"heading_002":{"id":"heading_002","type":"heading","category":"content","parentId":"slide_002","children":[],"content":{"text":"Confirm understanding"},"logic":{},"settings":{"headingLevel":"h3"},"layout":{}},"paragraph_002":{"id":"paragraph_002","type":"paragraph","category":"content","parentId":"slide_002","children":[],"content":{"richText":"Repeat the issue back in your own words so the customer knows they were heard and you solve the right problem."},"logic":{},"settings":{},"layout":{}},"slide_003":{"id":"slide_003","type":"slide","category":"content","parentId":"carousel_001","children":["heading_003","paragraph_003"],"content":{"caption":"Best practice 3"},"logic":{},"settings":{},"layout":{}},"heading_003":{"id":"heading_003","type":"heading","category":"content","parentId":"slide_003","children":[],"content":{"text":"Set clear next steps"},"logic":{},"settings":{"headingLevel":"h3"},"layout":{}},"paragraph_003":{"id":"paragraph_003","type":"paragraph","category":"content","parentId":"slide_003","children":[],"content":{"richText":"End every contact with who does what, by when. Certainty reduces repeat contacts."},"logic":{},"settings":{},"layout":{}}}},"state":{"uiState":{"selection":"carousel_001","expandedNodes":["carousel_001"],"activeView":"canvas"},"previewState":{"activeDevice":"desktop"},"undoState":{"snapshots":[],"currentIndex":-1}}}