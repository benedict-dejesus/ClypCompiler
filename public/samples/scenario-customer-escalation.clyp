’s actually going to be sorted this time."},"logic":{"speakerCharacterId":"character_001"},"settings":{"expression":"neutral","gesture":"neutral"},"layout":{}},"choice_004":{"id":"choice_004","type":"choice","category":"scenario","parentId":"scene_002","children":[],"content":{"label":"Take personal ownership and give a specific next step and time"},"logic":{"targetSceneId":"scene_003"},"settings":{},"layout":{}},"choice_005":{"id":"choice_005","type":"choice","category":"scenario","parentId":"scene_002","children":[],"content":{"label":"Transfer them to another department","feedbackText":"A cold transfer here reads as passing the problem on."},"logic":{"targetSceneId":"scene_004"},"settings":{},"layout":{}}}},"state":{"uiState":{"selection":"branchingScenario_001","expandedNodes":["branchingScenario_001"],"activeView":"canvas"},"previewState":{"activeDevice":"desktop"},"undoState":{"snapshots":[],"currentIndex":-1}}}