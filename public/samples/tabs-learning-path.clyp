{"project":{"name":"Learning Path Overview","uuid":"5650ca53-18f0-45aa-9b54-419dddbce52f","createdDate":"2026-07-17T10:57:27.587Z","modifiedDate":"2026-07-17T10:57:27.587Z","applicationVersion":"1.0.0","schemaVersion":"1.0.0"},"metadata":{"projectMetadata":{},"compilerMetadata":{"idCounters":{"tabs":1,"panel":4,"paragraph":4},"assetNameCounters":{}},"compatibilityMetadata":{"minSupportedSchemaVersion":"1.0.0","migrationsApplied":[]},"runtimeMetadata":{},"adapterMetadata":{}},"block":{"blockType":"tabs","rootId":"tabs_001","objects":{"tabs_001":{"id":"tabs_001","type":"tabs","category":"container","parentId":null,"children":["panel_001","panel_002","panel_003","panel_004"],"content":{},"logic":{},"settings":{"defaultActiveTab":0},"layout":{}},"panel_001":{"id":"panel_001","type":"panel","category":"content","parentId":"tabs_001","children":["paragraph_001"],"content":{"tabLabel":"Phase 1 · Foundations"},"logic":{},"settings":{},"layout":{}},"paragraph_001":{"id":"paragraph_001","type":"paragraph","category":"content","parentId":"panel_001","children":[],"content":{"richText":"Build shared language: leadership styles, feedback basics, and self-awareness. Expect reflection and a peer conversation."},"logic":{},"settings":{},"layout":{}},"panel_002":{"id":"panel_002","type":"panel","category":"content","parentId":"tabs_001","children":["paragraph_002"],"content":{"tabLabel":"Phase 2 · Practice"},"logic":{},"settings":{},"layout":{}},"paragraph_002":{"id":"paragraph_002","type":"paragraph","category":"content","parentId":"panel_002","children":[],"content":{"richText":"Apply skills in coached scenarios — difficult conversations, delegation, and prioritisation. Practice is deliberate and repeated."},"logic":{},"settings":{},"layout":{}},"panel_003":{"id":"panel_003","type":"panel","category":"content","parentId":"tabs_001","children":["paragraph_003"],"content":{"tabLabel":"Phase 3 · Apply"},"logic":{},"settings":{},"layout":{}},"paragraph_003":{"id":"paragraph_003","type":"paragraph","category":"content","parentId":"panel_003","children":[],"content":{"richText":"Lead a real initiative with a mentor. Bring evidence of impact to your final review."},"logic":{},"settings":{},"layout":{}},"panel_004":{"id":"panel_004","type":"panel","category":"content","parentId":"tabs_001","children":["paragraph_004"],"content":{"tabLabel":"Phase 4 · Sustain"},"logic":{},"settings":{},"layout":{}},"paragraph_004":{"id":"paragraph_004","type":"paragraph","category":"content","parentId":"panel_004","children":[],"content":{"richText":"Join the alumni cohort, set a 90-day development goal, and commit to a continuing peer group."},"logic":{},"settings":{},"layout":{}}}},"state":{"uiState":{"selection":"tabs_001","expandedNodes":["tabs_001"],"activeView":"canvas"},"previewState":{"activeDevice":"desktop"},"undoState":{"snapshots":[],"currentIndex":-1}}}