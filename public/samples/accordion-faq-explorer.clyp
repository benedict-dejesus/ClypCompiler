{"project":{"name":"FAQ Explorer","uuid":"ee1d7258-9966-49cb-ba7a-925682b61f24","createdDate":"2026-07-17T10:57:27.574Z","modifiedDate":"2026-07-17T10:57:27.574Z","applicationVersion":"1.0.0","schemaVersion":"1.0.0"},"metadata":{"projectMetadata":{},"compilerMetadata":{"idCounters":{"accordion":1,"panel":4,"paragraph":4},"assetNameCounters":{}},"compatibilityMetadata":{"minSupportedSchemaVersion":"1.0.0","migrationsApplied":[]},"runtimeMetadata":{},"adapterMetadata":{}},"block":{"blockType":"accordion","rootId":"accordion_001","objects":{"accordion_001":{"id":"accordion_001","type":"accordion","category":"container","parentId":null,"children":["panel_001","panel_002","panel_003","panel_004"],"content":{},"logic":{},"settings":{"expandBehavior":"multiOpen"},"layout":{}},"panel_001":{"id":"panel_001","type":"panel","category":"content","parentId":"accordion_001","children":["paragraph_001"],"content":{"title":"How do I request time off?"},"logic":{},"settings":{},"layout":{}},"paragraph_001":{"id":"paragraph_001","type":"paragraph","category":"content","parentId":"panel_001","children":[],"content":{"richText":"Open the HR portal, choose <b>Leave</b>, select your dates, and submit. Your manager is notified automatically and usually responds within two business days."},"logic":{},"settings":{},"layout":{}},"panel_002":{"id":"panel_002","type":"panel","category":"content","parentId":"accordion_001","children":["paragraph_002"],"content":{"title":"When am I paid?"},"logic":{},"settings":{},"layout":{}},"paragraph_002":{"id":"paragraph_002","type":"paragraph","category":"content","parentId":"panel_002","children":[],"content":{"richText":"Pay is deposited on the last working day of each month. Payslips are available in the portal from the 25th."},"logic":{},"settings":{},"layout":{}},"panel_003":{"id":"panel_003","type":"panel","category":"content","parentId":"accordion_001","children":["paragraph_003"],"content":{"title":"Who do I contact for IT issues?"},"logic":{},"settings":{},"layout":{}},"paragraph_003":{"id":"paragraph_003","type":"paragraph","category":"content","parentId":"panel_003","children":[],"content":{"richText":"Raise a ticket with the Service Desk or use the live chat in the intranet. Urgent outages: call extension 4000."},"logic":{},"settings":{},"layout":{}},"panel_004":{"id":"panel_004","type":"panel","category":"content","parentId":"accordion_001","children":["paragraph_004"],"content":{"title":"How do I book a meeting room?"},"logic":{},"settings":{},"layout":{}},"paragraph_004":{"id":"paragraph_004","type":"paragraph","category":"content","parentId":"panel_004","children":[],"content":{"richText":"Use the calendar add-in, search by capacity and floor, and confirm. Release rooms you no longer need so others can book them."},"logic":{},"settings":{},"layout":{}}}},"state":{"uiState":{"selection":"accordion_001","expandedNodes":["accordion_001"],"activeView":"canvas"},"previewState":{"activeDevice":"desktop"},"undoState":{"snapshots":[],"currentIndex":-1}}}